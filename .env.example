PORT=5005
# Use 'production' for any real/exposed deployment (avoids verbose error output).
# Only use 'development' for local development.
NODE_ENV=production
# REQUIRED: set a strong, unique password. Flame refuses to start if this is
# empty and warns loudly if left as the old default "flame_password".
PASSWORD=
# Leave SECRET as CHANGE_ME to have one auto-generated into data/secret.key
SECRET=CHANGE_ME
# Number of reverse-proxy hops in front of Flame (e.g. 1 for a single nginx/
# Traefik). Required for login rate limiting and access logs to see real client
# IPs. Leave unset if Flame is exposed directly.
# TRUST_PROXY=1
